sub create_gui
{
	$window = Gtk3::Window->new('toplevel');
	$window->set_title($APP_TITLE);
	$window->set_default_size(660, 820);

	set_app_icon($window);

	$webview = Gtk3::WebKit2::WebView->new();

	$webview->signal_connect('notify::title' => sub
	{
		handle_title_message();

		return TRUE;
	});

	$window->add($webview);

	$window->signal_connect(delete_event => sub
	{
		return try_quit();
	});

	$webview->load_html(html_page(), 'file:///');

	$window->show_all();

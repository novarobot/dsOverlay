<script>
let state =
{
	project_dir: "",
	hierarchy_file: "",
	hierarchy_dir: "",
	dsoverlay_bin: "",
	items: [],
	dirty: 0,
	dirty_since_remount: 0,
	is_root: 0,
	overlay_mounted: 0,
	overlay_out_dir: ""
};

let browseMode = "";
let editIndex = -1;
let msgSeq = 0;
let selectedRow = -1;

function send(obj)
{
	msgSeq++;
	document.title = "DSMSG:" + msgSeq + ":" + encodeURIComponent(JSON.stringify(obj));
}

function pad2(n)
{
	return String(n).padStart(2, "0");
}

function render()
{
	document.getElementById("projectDir").textContent = state.project_dir;
	document.getElementById("hierarchyFile").textContent = state.hierarchy_file;
	document.getElementById("dsOverlayBin").textContent = state.dsoverlay_bin;
	document.getElementById("rootState").textContent = state.is_root ? "root joggal fut" : "normál felhasználói joggal fut";

	const mountState = document.getElementById("mountState");

	if (state.overlay_mounted)
	{
		mountState.innerHTML = '<span class="mountOn">MOUNT BE</span> — ' + state.overlay_out_dir;
	}
	else
	{
		mountState.innerHTML = '<span class="mountOff">MOUNT KI</span> — ' + state.overlay_out_dir;
	}

	const list = document.getElementById("list");

	if (selectedRow >= state.items.length)
	{
		selectedRow = state.items.length - 1;
	}

	list.innerHTML = "";

	for (let i = 0; i < state.items.length; i++)
	{
		const item = state.items[i];

		const row = document.createElement("div");
		row.className = "listRow";
		row.dataset.index = String(i);

		if (!item.enabled)
		{
			row.className += " disabledItem";
		}

		if (i === selectedRow)
		{
			row.className += " selectedItem";
		}

		let prefix = item.enabled ? "[ON ] " : "[OFF] ";
		row.textContent = pad2(i + 1) + "  " + prefix + item.path;

		row.onclick = function()
		{
			selectedRow = i;
			render();
			document.getElementById("list").focus();
		};

		row.ondblclick = function()
		{
			selectedRow = i;
			editItem();
		};

		list.appendChild(row);
	}

	let txt = "";

	if (state.dirty)
	{
		txt += '<span class="warn">Van nem mentett módosítás.</span><br>';
	}
	else
	{
		txt += '<span class="ok">A hierarchia.txt mentett állapotban van.</span><br>';
	}

	if (state.dirty_since_remount)
	{
		txt += '<span class="warn">Volt szerkesztés az utolsó remount óta.</span>';
	}
	else
	{
		txt += '<span class="ok">Nincs remount nélküli szerkesztés.</span>';
	}

	document.getElementById("status").innerHTML = txt;
}

window.dsSetState = function(newState)
{
	state = newState;

	if (selectedRow < 0 && state.items.length > 0)
	{
		selectedRow = 0;
	}

	render();
};

window.dsBrowseResult = function(path)
{
	if (!path)
	{
		return;
	}

	if (browseMode === "new")
	{
		state.items.push(
		{
			enabled: 1,
			path: path
		});

		selectedRow = state.items.length - 1;
		state.dirty = 1;
		saveItems();
	}
	else if (browseMode === "edit")
	{
		if (editIndex >= 0 && editIndex < state.items.length)
		{
			state.items[editIndex].path = path;
			selectedRow = editIndex;
			state.dirty = 1;
			saveItems();
		}
	}

	browseMode = "";
	editIndex = -1;
};

function selectedIndex()
{
	return selectedRow;
}

function addItem()
{
	browseMode = "new";
	editIndex = -1;
	send({cmd: "browse_new"});
}

function editItem()
{
	const idx = selectedIndex();

	if (idx < 0 || idx >= state.items.length)
	{
		alert("Nincs kiválasztott elem.");
		return;
	}

	browseMode = "edit";
	editIndex = idx;

	send({cmd: "browse_edit", index: idx});
}

function deleteItem()
{
	const idx = selectedIndex();

	if (idx < 0 || idx >= state.items.length)
	{
		alert("Nincs kiválasztott elem.");
		return;
	}

	if (!confirm("Biztosan törlöd ezt az elemet?\n\n" + state.items[idx].path))
	{
		return;
	}

	state.items.splice(idx, 1);

	if (selectedRow >= state.items.length)
	{
		selectedRow = state.items.length - 1;
	}

	state.dirty = 1;
	saveItems();
}

function toggleItem()
{
	const idx = selectedIndex();

	if (idx < 0 || idx >= state.items.length)
	{
		alert("Nincs kiválasztott elem.");
		return;
	}

	state.items[idx].enabled = state.items[idx].enabled ? 0 : 1;
	selectedRow = idx;
	state.dirty = 1;
	saveItems();
}

function moveUp()
{
	const idx = selectedIndex();

	if (idx <= 0 || idx >= state.items.length)
	{
		return;
	}

	const tmp = state.items[idx - 1];
	state.items[idx - 1] = state.items[idx];
	state.items[idx] = tmp;

	selectedRow = idx - 1;
	state.dirty = 1;
	saveItems();
}

function moveDown()
{
	const idx = selectedIndex();

	if (idx < 0 || idx >= state.items.length - 1)
	{
		return;
	}

	const tmp = state.items[idx + 1];
	state.items[idx + 1] = state.items[idx];
	state.items[idx] = tmp;

	selectedRow = idx + 1;
	state.dirty = 1;
	saveItems();
}

function saveItems()
{
	send({cmd: "save_items", items: state.items});
}

function remount()
{
	send({cmd: "remount"});
}

function umountOverlay()
{
	send({cmd: "umount"});
}

function quitApp()
{
	send({cmd: "quit"});
}

document.addEventListener("keydown", function(e)
{
	if (document.activeElement.id !== "list")
	{
		return;
	}

	if (e.key === "ArrowUp")
	{
		if (selectedRow > 0)
		{
			selectedRow--;
			render();
		}

		e.preventDefault();
		return;
	}

	if (e.key === "ArrowDown")
	{
		if (selectedRow < state.items.length - 1)
		{
			selectedRow++;
			render();
		}

		e.preventDefault();
		return;
	}

	if (e.key === "Enter")
	{
		editItem();
		e.preventDefault();
		return;
	}

	if (e.key === " ")
	{
		toggleItem();
		e.preventDefault();
		return;
	}

	if (e.key === "Delete")
	{
		deleteItem();
		e.preventDefault();
		return;
	}
});

window.onload = function()
{
	send({cmd: "ready"});
};
</script>

sub can_drop_to_original_user
{
	return 0 if !is_root();
	return 0 if !defined $ORIGINAL_UID;
	return 0 if !defined $ORIGINAL_GID;
	return 0 if $ORIGINAL_UID <= 0;

	return 1;
}

sub run_as_original_user
{
	my ($callback) = @_;

	if (!can_drop_to_original_user())
	{
		return $callback->();
	}

	my $old_euid = $>;
	my $old_egid = $);
	my $old_home = $ENV{'HOME'};
	my $old_user = $ENV{'USER'};
	my $old_logname = $ENV{'LOGNAME'};

	my @result;

	eval
	{
		$) = "$ORIGINAL_GID $ORIGINAL_GID";
		$> = $ORIGINAL_UID;

		if ($ORIGINAL_HOME ne '')
		{
			$ENV{'HOME'} = $ORIGINAL_HOME;
		}

		if ($ORIGINAL_USER ne '')
		{
			$ENV{'USER'} = $ORIGINAL_USER;
			$ENV{'LOGNAME'} = $ORIGINAL_USER;
		}

		@result = $callback->();

		$> = $old_euid;
		$) = $old_egid;

		if (defined $old_home)
		{
			$ENV{'HOME'} = $old_home;
		}
		else
		{
			delete $ENV{'HOME'};
		}

		if (defined $old_user)
		{
			$ENV{'USER'} = $old_user;
		}
		else
		{
			delete $ENV{'USER'};
		}

		if (defined $old_logname)
		{
			$ENV{'LOGNAME'} = $old_logname;
		}
		else
		{
			delete $ENV{'LOGNAME'};
		}
	};

	if ($@)
	{
		my $err = $@;

		eval
		{
			$> = $old_euid;
			$) = $old_egid;
		};

		die_gui("Nem sikerült ideiglenesen az eredeti user nevében futtatni a műveletet:\n\n$err");
	}

	return wantarray ? @result : $result[0];
}

sub select_project_dir
{
	my $dirname = run_as_original_user(sub
	{
		my $dialog = Gtk3::FileChooserDialog->new(
			'Válaszd ki a dsOverlay projektmappát',
			undef,
			'select-folder',
			'gtk-cancel' => 'cancel',
			'gtk-open' => 'accept'
		);

		set_app_icon($dialog);

		my $response = $dialog->run();
		my $dirname_inner = '';

		if ($response eq 'accept')
		{
			$dirname_inner = $dialog->get_filename();
		}

		close_dialog_cleanly($dialog);

		return $dirname_inner;
	});

	return $dirname // '';
}

sub default_lower_abs_path
{
	my ($proj_dir) = @_;

	my $lower_path = $DEFAULT_LOWER_DIR;

	if ($lower_path !~ m{^/})
	{
		$lower_path = File::Spec->catdir($proj_dir, $lower_path);
	}

	return $lower_path;
}

sub chmod_777_if_exists
{
	my ($path) = @_;

	return if !defined $path;
	return if $path eq '';
	return if !-e $path;

	chmod 0777, $path;
}

sub try_create_default_hierarchy
{
	my ($proj_dir, $show_error) = @_;

	my $hierarchy_path = File::Spec->catfile($proj_dir, 'hierarchia.txt');
	my $lower_path = default_lower_abs_path($proj_dir);

	if (-f $hierarchy_path)
	{
		return 1;
	}

	if (!-d $lower_path)
	{
		eval
		{
			make_path($lower_path);
		};

		if ($@ || !-d $lower_path)
		{
			my $msg =
				"Nem sikerült létrehozni az alapértelmezett lower mappát:\n\n" .
				"$lower_path\n\n" .
				"A hierarchia.txt fájlt ezért nem hozom létre.";

			if ($show_error)
			{
				show_error_no_parent($msg);
			}
			else
			{
				show_warning_no_parent($msg);
			}

			return 0;
		}

		chmod_777_if_exists($lower_path);
	}

	open(my $fh, '>:encoding(UTF-8)', $hierarchy_path);

	if (!$fh)
	{
		my $msg =
			"Az alapértelmezett lower mappa létrejött, de a hierarchia.txt létrehozása nem sikerült:\n\n" .
			"$hierarchy_path\n\n" .
			"$!";

		if ($show_error)
		{
			show_error_no_parent($msg);
		}
		else
		{
			show_warning_no_parent($msg);
		}

		return 0;
	}

	print $fh "$DEFAULT_HIERARCHY_LINE\n";
	close($fh);

	chmod_777_if_exists($hierarchy_path);

	return 1;
}

sub select_project_dir_with_optional_create
{
	while (1)
	{
		my $selected_dir = select_project_dir();

		if ($selected_dir eq '')
		{
			exit 0;
		}

		my $proj_dir = canonical_dir($selected_dir);

		if ($proj_dir eq '')
		{
			show_warning_no_parent(
				"A kiválasztott projektmappa nem létezik vagy nem könyvtár:\n\n" .
				"$selected_dir"
			);

			next;
		}

		my $hierarchy_path = File::Spec->catfile($proj_dir, 'hierarchia.txt');

		if (-f $hierarchy_path)
		{
			return $proj_dir;
		}

		my $yes = ask_yes_no_no_parent(
			"Ebben a projektmappában nincs hierarchia.txt:\n\n" .
			"$proj_dir\n\n" .
			"Létrehozzam?\n\n" .
			"Először ez a mappa jön létre:\n" .
			default_lower_abs_path($proj_dir) . "\n\n" .
			"Csak ezután jön létre a hierarchia.txt ezzel a kezdő sorral:\n" .
			"$DEFAULT_HIERARCHY_LINE\n\n" .
			"Ha a lower mappa létrehozása nem sikerül, a TXT-t meg sem próbálom létrehozni."
		);

		if (!$yes)
		{
			next;
		}

		try_create_default_hierarchy($proj_dir, 0);

		return $proj_dir;
	}
}

sub restart_self_with_pkexec_if_needed
{
	my ($proj_dir) = @_;

	if (is_root())
	{
		return;
	}

	if (exists $ENV{'DSOVERLAYGUI_PKEXEC_TRIED'})
	{
		warn "Nem root joggal futok, de a pkexec próbálkozás már megtörtént. Folytatás normál joggal.\n";
		return;
	}

	my $script = abs_path($0);

	if (!defined $script || $script eq '')
	{
		warn "Nem tudom feloldani a saját script útvonalát. Folytatás normál joggal.\n";
		return;
	}

	my $pkexec = `command -v pkexec 2>/dev/null`;
	chomp($pkexec);

	if ($pkexec eq '')
	{
		warn "Nincs pkexec a rendszeren. Folytatás normál joggal.\n";
		return;
	}

	system('sh', '-c', 'command -v xhost >/dev/null 2>&1 && xhost +SI:localuser:root >/dev/null 2>&1');

	my @env_args = (
		'DSOVERLAYGUI_PKEXEC_TRIED=1',
		'DSOVERLAYGUI_ORIGINAL_UID=' . $ORIGINAL_UID,
		'DSOVERLAYGUI_ORIGINAL_GID=' . $ORIGINAL_GID,
		'DSOVERLAYGUI_ORIGINAL_USER=' . $ORIGINAL_USER,
		'DSOVERLAYGUI_ORIGINAL_HOME=' . $ORIGINAL_HOME,
	);

	foreach my $key (
		'DISPLAY',
		'XAUTHORITY',
		'WAYLAND_DISPLAY',
		'XDG_RUNTIME_DIR',
		'DBUS_SESSION_BUS_ADDRESS',
		'LANG',
		'LC_ALL',
		'LC_CTYPE'
	)
	{
		if (exists $ENV{$key} && defined $ENV{$key} && $ENV{$key} ne '')
		{
			push @env_args, $key . '=' . $ENV{$key};
		}
	}

	my @cmd = (
		$pkexec,
		'env',
		@env_args,
		$^X,
		$script,
		$proj_dir
	);

	my $ret = system(@cmd);

	if ($ret == 0)
	{
		exit 0;
	}

	my $exit_code = $ret >> 8;

	warn "A pkexec újraindítás nem sikerült vagy megszakadt. Exit code: $exit_code. Folytatás normál joggal.\n";

	return;
}

sub init_paths
{
	my @args = @ARGV;

	if (@args >= 1)
	{
		$project_dir = canonical_dir($args[0]);

		if ($project_dir eq '')
		{
			die "Nem létező projekt mappa: $args[0]\n";
		}
	}
	else
	{
		$project_dir = select_project_dir_with_optional_create();
	}

	restart_self_with_pkexec_if_needed($project_dir);

	my $hierarchy_path = File::Spec->catfile($project_dir, 'hierarchia.txt');

	if (!-f $hierarchy_path)
	{
		my $ok = try_create_default_hierarchy($project_dir, 1);

		if (!$ok || !-f $hierarchy_path)
		{
			show_error_no_parent(
				"Nem sikerült létrehozni a hierarchia.txt fájlt:\n\n" .
				"$hierarchy_path\n\n" .
				"A program kilép."
			);

			exit 1;
		}
	}

	$hierarchy_file = File::Spec->catfile($project_dir, 'hierarchia.txt');

	my $abs_file = abs_path($hierarchy_file);

	if (!defined $abs_file || !-f $abs_file)
	{
		die "Nem létező vagy nem feloldható hierarchia fájl: $hierarchy_file\n";
	}

	$hierarchy_file = $abs_file;
	$hierarchy_dir = dirname($hierarchy_file);
}

sub load_hierarchy
{
	@items = ();

	open(my $fh, '<:encoding(UTF-8)', $hierarchy_file) or die_gui("Nem tudom olvasni:\n$hierarchy_file\n\n$!");

	while (my $line = <$fh>)
	{
		chomp($line);
		$line =~ s/\r$//;

		my $clean = trim_line($line);

		next if $clean eq '';

		my $enabled = 1;
		my $path = $clean;

		if ($path =~ /^#/)
		{
			$enabled = 0;
			$path =~ s/^#//;
			$path = trim_line($path);
		}

		push @items, {
			enabled => $enabled ? 1 : 0,
			path => $path,
		};
	}

	close($fh);

	$dirty = 0;
	$dirty_since_remount = 0;
}

sub save_hierarchy
{
	open(my $fh, '>:encoding(UTF-8)', $hierarchy_file) or die_gui("Nem tudom írni:\n$hierarchy_file\n\n$!");

	foreach my $item (@items)
	{
		my $path = trim_line($item->{path} // '');

		next if $path eq '';

		if ($item->{enabled})
		{
			print $fh "$path\n";
		}
		else
		{
			print $fh "#$path\n";
		}
	}

	close($fh);

	$dirty = 0;
	$dirty_since_remount = 1;
}

sub make_relative_if_inside
{
	my ($selected) = @_;

	my $abs_selected = abs_path($selected);

	if (!defined $abs_selected || $abs_selected eq '')
	{
		$abs_selected = File::Spec->rel2abs($selected);
	}

	my $base = abs_path($hierarchy_dir);

	if (!defined $base || $base eq '')
	{
		return $selected;
	}

	if ($abs_selected eq $base)
	{
		return './';
	}

	my $prefix = $base . '/';

	if (index($abs_selected, $prefix) == 0)
	{
		my $rest = substr($abs_selected, length($prefix));
		return './' . $rest;
	}

	return $abs_selected;
}

sub resolve_item_start_dir
{
	my ($item) = @_;

	if (!defined $item)
	{
		return $hierarchy_dir;
	}

	my $path = $item->{path} // '';

	if ($path eq '')
	{
		return $hierarchy_dir;
	}

	if ($path !~ m{^/})
	{
		$path = File::Spec->catdir($hierarchy_dir, $path);
	}

	my $abs = abs_path($path);

	if (defined $abs && -d $abs)
	{
		return $abs;
	}

	return $hierarchy_dir;
}

sub choose_directory
{
	my ($start_dir) = @_;

	my $selected = run_as_original_user(sub
	{
		my $dialog = Gtk3::FileChooserDialog->new(
			'Válassz mappát',
			$window,
			'select-folder',
			'gtk-cancel' => 'cancel',
			'gtk-open' => 'accept'
		);

		set_app_icon($dialog);

		if (defined $start_dir && $start_dir ne '' && -d $start_dir)
		{
			$dialog->set_current_folder($start_dir);
		}
		else
		{
			$dialog->set_current_folder($hierarchy_dir);
		}

		my $response = $dialog->run();
		my $selected_inner = '';

		if ($response eq 'accept')
		{
			$selected_inner = $dialog->get_filename();
		}

		close_dialog_cleanly($dialog);

		return $selected_inner;
	});

	if (!defined $selected || $selected eq '')
	{
		return '';
	}

	return make_relative_if_inside($selected);
}

sub get_overlay_mount_status
{
	my $out_dir = File::Spec->catdir($project_dir, 'out');

	if (!-d $out_dir)
	{
		return (0, $out_dir);
	}

	my $ret = system('mountpoint', '-q', $out_dir);

	if ($ret == 0)
	{
		return (1, $out_dir);
	}

	return (0, $out_dir);
}

sub refresh_web
{
	my ($overlay_mounted, $overlay_out_dir) = get_overlay_mount_status();

	my $payload = {
		project_dir => $project_dir,
		hierarchy_file => $hierarchy_file,
		hierarchy_dir => $hierarchy_dir,
		dsoverlay_bin => $DSOVERLAY_BIN,
		items => \@items,
		dirty => $dirty ? 1 : 0,
		dirty_since_remount => $dirty_since_remount ? 1 : 0,
		is_root => is_root() ? 1 : 0,
		overlay_mounted => $overlay_mounted ? 1 : 0,
		overlay_out_dir => $overlay_out_dir,
	};

	my $encoded = $json->encode($payload);

	js_call('window.dsSetState(' . $encoded . ');');
}

sub set_items_from_payload
{
	my ($data) = @_;

	if (ref($data->{items}) ne 'ARRAY')
	{
		die_gui('Hibás items mező');
	}

	@items = ();

	foreach my $in_item (@{$data->{items}})
	{
		next if ref($in_item) ne 'HASH';

		my $path = trim_line($in_item->{path} // '');

		next if $path eq '';

		my $enabled = $in_item->{enabled} ? 1 : 0;

		push @items, {
			enabled => $enabled,
			path => $path,
		};
	}

	save_hierarchy();
	refresh_web();
}

sub has_parent_terminal
{
	if (-t STDIN || -t STDERR)
	{
		return 1;
	}

	return 0;
}

sub command_exists
{
	my ($cmd) = @_;

	return 0 if !defined $cmd;
	return 0 if $cmd eq '';

	my $ret = system('sh', '-c', 'command -v "$1" >/dev/null 2>&1', 'sh', $cmd);

	return ($ret == 0) ? 1 : 0;
}

sub make_terminal_command
{
	my ($terminal, $terminal_cmd) = @_;

	if ($terminal eq 'gnome-terminal')
	{
		return ($terminal, '--', 'bash', '-lc', $terminal_cmd);
	}

	if ($terminal eq 'xfce4-terminal')
	{
		return ($terminal, '-e', 'bash -lc ' . shell_quote($terminal_cmd));
	}

	if ($terminal eq 'mate-terminal')
	{
		return ($terminal, '-e', 'bash -lc ' . shell_quote($terminal_cmd));
	}

	if ($terminal eq 'konsole')
	{
		return ($terminal, '-e', 'bash', '-lc', $terminal_cmd);
	}

	if ($terminal eq 'xterm')
	{
		return ($terminal, '-e', 'bash', '-lc', $terminal_cmd);
	}

	if ($terminal eq 'x-terminal-emulator')
	{
		return ($terminal, '-e', 'bash', '-lc', $terminal_cmd);
	}

	return ($terminal, '-e', 'bash', '-lc', $terminal_cmd);
}

sub unique_terminal_list
{
	my @in = @_;
	my %seen = ();
	my @out = ();

	foreach my $t (@in)
	{
		next if !defined $t;
		next if $t eq '';

		if (!$seen{$t})
		{
			push @out, $t;
			$seen{$t} = 1;
		}
	}

	return @out;
}

sub start_terminal_command_and_wait
{
	my ($terminal_cmd) = @_;

	my @tried = ();
	my @not_found = ();
	my @failed_start = ();

	my @terminals = unique_terminal_list(
		$PREFERRED_TERMINAL,
		$SYSTEM_TERMINAL_CANDIDATE,
		'x-terminal-emulator',
		'gnome-terminal',
		'xfce4-terminal',
		'mate-terminal',
		'konsole',
		'xterm'
	);

	foreach my $terminal (@terminals)
	{
		push @tried, $terminal;

		if (!command_exists($terminal))
		{
			push @not_found, $terminal;
			next;
		}

		my @exec_cmd = make_terminal_command($terminal, $terminal_cmd);

		my $pid = fork();

		if (!defined $pid)
		{
			push @failed_start, "$terminal - fork hiba";
			next;
		}

		if ($pid == 0)
		{
			exec @exec_cmd;
			exit 127;
		}

		waitpid($pid, 0);

		my $ret = $?;

		if ($ret == -1)
		{
			push @failed_start, "$terminal - waitpid hiba";
			return (0, 255, $terminal);
		}

		if ($ret & 127)
		{
			my $signal = $ret & 127;
			return (0, 128 + $signal, $terminal);
		}

		my $exit_code = $ret >> 8;

		return (($exit_code == 0) ? 1 : 0, $exit_code, $terminal);
	}

	my $msg = "Nem találok használható terminál emulátort.\n\n";

	$msg .= "Beállított terminál:\n";
	$msg .= "  " . ($PREFERRED_TERMINAL ne '' ? $PREFERRED_TERMINAL : '(nincs megadva)') . "\n\n";

	$msg .= "Rendszer alapértelmezett terminál jelölt:\n";
	$msg .= "  $SYSTEM_TERMINAL_CANDIDATE\n\n";

	$msg .= "Próbált terminálok:\n";
	foreach my $t (@tried)
	{
		$msg .= "  $t\n";
	}

	if (@not_found)
	{
		$msg .= "\nNem található parancsok:\n";

		foreach my $t (@not_found)
		{
			$msg .= "  $t\n";
		}
	}

	if (@failed_start)
	{
		$msg .= "\nIndítási hibák:\n";

		foreach my $t (@failed_start)
		{
			$msg .= "  $t\n";
		}
	}

	$msg .= "\nMegoldás:\n";
	$msg .= "  - állítsd be a script elején a \$PREFERRED_TERMINAL változót,\n";
	$msg .= "  - vagy telepíts egy terminált,\n";
	$msg .= "  - vagy indítsd a dsOverlayGUI-t terminálból.\n\n";

	die_gui($msg);

	return (0, 255, '');
}

sub run_dsoverlay
{
	my ($cmd) = @_;

	save_hierarchy() if $dirty;

	my @cmd = ($DSOVERLAY_BIN, $cmd, $project_dir);
	my $cmd_text = join(' ', map { shell_quote($_) } @cmd);

	if (is_root())
	{
		my $dialog = Gtk3::MessageDialog->new(
			$window,
			'destroy-with-parent',
			'info',
			'ok',
			"Root joggal futó GUI.\n\nParancs közvetlen indítása:\n$cmd_text\n\nAz OK után lefut a dsOverlay."
		);

		set_app_icon($dialog);

		$dialog->set_title('dsOverlay indítása');
		$dialog->run();

		close_dialog_cleanly($dialog);

		my $ret = system(@cmd);

		if ($ret == 0)
		{
			return 1;
		}

		my $exit_code = $ret >> 8;

		die_gui(
			"A dsOverlay hibával tért vissza.\n\n" .
			"Rootként futó GUI-ból indítva.\n\n" .
			"Parancs:\n$cmd_text\n\n" .
			"Exit code: $exit_code"
		);

		return 0;
	}

	if (has_parent_terminal())
	{
		my $dialog = Gtk3::MessageDialog->new(
			$window,
			'destroy-with-parent',
			'info',
			'ok',
			"Parancs indítása a meglévő terminálban:\n$cmd_text\n\nAz OK után indul a dsOverlay.\nHa sudo jelszót kér, azt ebben a terminálban add meg."
		);

		set_app_icon($dialog);

		$dialog->set_title('dsOverlay indítása');
		$dialog->run();

		close_dialog_cleanly($dialog);

		my $ret = system(@cmd);

		if ($ret == 0)
		{
			return 1;
		}

		my $exit_code = $ret >> 8;

		die_gui("A dsOverlay hibával tért vissza.\n\nParancs:\n$cmd_text\n\nExit code: $exit_code");

		return 0;
	}

	my $start_dialog = Gtk3::MessageDialog->new(
		$window,
		'destroy-with-parent',
		'info',
		'ok',
		"Parancs indítása külön terminálban:\n$cmd_text\n\nAz OK után megnyílik egy terminál.\nHa sudo jelszót kér, azt ott add meg.\n\nA sikeres futás üzenete csak a terminál bezárása után jelenik meg."
	);

	set_app_icon($start_dialog);

	$start_dialog->set_title('dsOverlay indítása');
	$start_dialog->run();

	close_dialog_cleanly($start_dialog);

	my $terminal_cmd =
		$cmd_text .
		'; ds_overlay_ret=$?' .
		'; echo' .
		'; echo "dsOverlay exit code: $ds_overlay_ret"' .
		'; echo' .
		'; echo "Nyomj ENTER-t az ablak bezárásához..."' .
		'; read dummy' .
		'; exit $ds_overlay_ret';

	my ($ok, $exit_code, $used_terminal) = start_terminal_command_and_wait($terminal_cmd);

	if (!$ok)
	{
		die_gui(
			"A dsOverlay hibával tért vissza vagy a terminál hibával zárult.\n\n" .
			"Terminál:\n$used_terminal\n\n" .
			"Parancs:\n$cmd_text\n\n" .
			"Exit code: $exit_code"
		);

		return 0;
	}

	return 1;
}

sub do_remount
{
	my $ok = run_dsoverlay('remount');

	if ($ok)
	{
		$dirty_since_remount = 0;
		refresh_web();
		info_gui('Remount kész.');
	}
}

sub do_umount
{
	my $ok = run_dsoverlay('umount');

	if ($ok)
	{
		refresh_web();
		info_gui('Umount kész.');
	}
}

sub handle_message
{
	my ($msg_text) = @_;

	my $data;

	eval
	{
		$data = $json->decode($msg_text);
	};

	if ($@)
	{
		die_gui("Hibás JSON üzenet:\n$@");
		return;
	}

	my $cmd = $data->{cmd} // '';

	if ($cmd eq 'ready')
	{
		refresh_web();
		return;
	}

	if ($cmd eq 'save_items')
	{
		set_items_from_payload($data);
		return;
	}

	if ($cmd eq 'browse_new')
	{
		my $selected = choose_directory($hierarchy_dir);

		if ($selected ne '')
		{
			js_call('window.dsBrowseResult(' . js_string($selected) . ');');
		}

		return;
	}

	if ($cmd eq 'browse_edit')
	{
		my $index = $data->{index};
		my $item = undef;

		if (defined $index && $index =~ /^\d+$/ && $index >= 0 && $index < @items)
		{
			$item = $items[$index];
		}

		my $start = resolve_item_start_dir($item);
		my $selected = choose_directory($start);

		if ($selected ne '')
		{
			js_call('window.dsBrowseResult(' . js_string($selected) . ');');
		}

		return;
	}

	if ($cmd eq 'remount')
	{
		do_remount();
		return;
	}

	if ($cmd eq 'umount')
	{
		do_umount();
		return;
	}

	if ($cmd eq 'quit')
	{
		try_quit();
		return;
	}

	die_gui("Ismeretlen parancs: $cmd");
}

sub try_quit
{
	my ($overlay_mounted, $overlay_out_dir) = get_overlay_mount_status();
	my @warnings = ();

	if ($dirty_since_remount)
	{
		push @warnings, "Volt szerkesztés az utolsó remount óta.";
	}

	if ($overlay_mounted)
	{
		push @warnings,
			"Az overlay mount továbbra is aktív:\n" .
			$overlay_out_dir . "\n\n" .
			"A program kilépéskor NEM csatolja le a projektet.";
	}

	if (@warnings)
	{
		my $message = join("\n\n", @warnings);
		$message .= "\n\nBiztosan kilépsz?";

		my $yes = ask_yes_no($message);

		if (!$yes)
		{
			return TRUE;
		}
	}

	Gtk3->main_quit();

	return FALSE;
}

sub handle_title_message
{
	my $title = $webview->get_title();

	return if !defined $title;
	return if $title eq $last_title_message;

	$last_title_message = $title;

	return if $title !~ /^DSMSG:/;

	my $encoded = $title;
	$encoded =~ s/^DSMSG:\d+://;

	my $decoded = uri_unescape($encoded);

	handle_message($decoded);
}


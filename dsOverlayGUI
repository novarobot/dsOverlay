sub is_root
{
	return ($> == 0) ? 1 : 0;
}

sub flush_gtk_events
{
	while (Gtk3::events_pending())
	{
		Gtk3::main_iteration();
	}
}

sub create_pixbuf_from_base64
{
	my ($base64_data) = @_;

	return undef if !defined $base64_data;

	$base64_data =~ s/\s+//g;

	return undef if $base64_data eq '';

	my $image_data = decode_base64($base64_data);
	my $loader = Gtk3::Gdk::PixbufLoader->new();

	eval
	{
		$loader->write($image_data);
		$loader->close();
	};

	if ($@)
	{
		warn "Nem sikerült betölteni a base64 ikont: $@\n";
		return undef;
	}

	return $loader->get_pixbuf();
}

sub get_app_icon_pixbuf
{
	if (defined $APP_ICON_PIXBUF)
	{
		return $APP_ICON_PIXBUF;
	}

	$APP_ICON_PIXBUF = create_pixbuf_from_base64($APP_ICON_BASE64);

	return $APP_ICON_PIXBUF;
}

sub set_app_icon
{
	my ($target_window) = @_;

	my $pixbuf = get_app_icon_pixbuf();

	if (!defined $pixbuf)
	{
		return;
	}

	eval
	{
		Gtk3::Window::set_default_icon($pixbuf);
	};

	if (defined $target_window)
	{
		eval
		{
			$target_window->set_icon($pixbuf);
		};

		if ($@)
		{
			warn "Nem sikerült beállítani az ablak ikonját: $@\n";
		}
	}
}

sub close_dialog_cleanly
{
	my ($dialog) = @_;

	return if !defined $dialog;

	$dialog->hide();
	$dialog->destroy();

	flush_gtk_events();
	select(undef, undef, undef, 0.05);
	flush_gtk_events();
}

sub trim_line
{
	my ($line) = @_;

	$line =~ s/\r?\n$//;
	$line =~ s/^\s+//;
	$line =~ s/\s+$//;

	return $line;
}

sub uri_unescape
{
	my ($s) = @_;

	$s =~ s/%([0-9A-Fa-f]{2})/chr(hex($1))/eg;

	return $s;
}

sub canonical_dir
{
	my ($path) = @_;

	my $abs = abs_path($path);

	if (!defined $abs || $abs eq '')
	{
		return '';
	}

	if (!-d $abs)
	{
		return '';
	}

	return $abs;
}

sub js_string
{
	my ($s) = @_;

